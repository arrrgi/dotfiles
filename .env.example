# Chezmoi Environment Variables Example
#
# Copy this file to .env and replace the placeholder values with your actual
# credentials before running `chezmoi init --apply arrrgi`.
#
# IMPORTANT: Never commit the populated .env file to version control! The included
# gitignore file will prevent this, but it's still a good idea to be cautious.

# =============================================================================
# Git Configuration (Required for MacOS and WSL)
# =============================================================================

# Your full name (used in Git commits)
# Required for: MacOS, WSL
export GIT_NAME="Your Full Name"

# Your Git email address (used in Git commits)
# Required for: MacOS, WSL
export GIT_EMAIL="your.email@example.com"

# Your GitHub username
# Required for: MacOS
export GIT_GH_USERNAME="your-github-username"

# Your Azure DevOps username
# Required for: WSL
export GIT_ADO_USERNAME="your-ado-username"

# Your Azure DevOps organization
# Required for: WSL
export GIT_ADO_ORG="your-ado-org"

# =============================================================================
# AWS Configuration (Required for MacOS, WSL, and Ubuntu Home Lab)
# =============================================================================

# AWS Access Key ID
# Required for: MacOS, WSL, Ubuntu Home Lab
export AWS_ACCESS_KEY_ID="EXAMPLEKEYID"

# AWS Secret Access Key
# Required for: MacOS, WSL, Ubuntu Home Lab
export AWS_SECRET_ACCESS_KEY="EXAMPLEACCESSKEY"

# AWS Region
# Required for: MacOS, WSL, Ubuntu Home Lab
export AWS_REGION="ap-southeast-2"
