*/}}

{{- $packages := splitList " " (includeTemplate "universal/brews.def" .) }}
{{- $taps := list
  "bellicose100xp/tap"
  "olets/tap"
-}}

{{/* insert MacOS specific packages here */}}
{{- $brews := concat $packages (list
  "coreutils"
  "doctl"
  "gh"
  "glow"
  "gnu-sed"
  "gnu-tar"
  "grep"
  "hadolint"
  "httpie"
  "imagemagick"
  "mise"
  "shellcheck"
  "thefuck"
  "yt-dlp"
)
-}}

{{- $crates := list
  "tokenusage"
-}}

{{- $casks := list
  "1password"
  "1password-cli"
  "antinote"
  "arq"
  "cleanshot"
  "codex"
  "discord"
  "fastmail"
  "firefox"
  "font-maple-mono-nf"
  "ghostty"
  "google-drive"
  "iina"
  "jordanbaird-ice"
  "obsidian"
  "orbstack"
  "raycast"
  "tailscale-app"
  "telegram"
  "todoist-app"
  "visual-studio-code"
  "windows-app"
  "zed"
-}}

{{ range ($taps | sortAlpha | uniq) -}}
tap "{{ . }}"
{{ end -}}
{{ range ($brews | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end -}}
{{ range ($crates | sortAlpha | uniq) -}}
cargo "{{ . }}"
{{ end -}}
{{ range ($casks | sortAlpha | uniq) -}}
cask "{{ . }}"
{{ end -}}
