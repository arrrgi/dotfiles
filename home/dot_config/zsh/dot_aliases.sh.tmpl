# Useful shortcuts
alias _='sudo '
# alias sudo='sudo '
alias reload='exec ${SHELL} -l'

# Navigation
alias -g ...='../..'
alias -g ....='../../..'
alias -g .....='../../../..'
alias -g ......='../../../../..'

alias egrep='grep -E'
alias fgrep='grep -F'

# Command substitutions
# LSD is a modern replacement for ls
if command -v lsd &> /dev/null; then
  alias ls='lsd'
  alias la='ls -A'
  alias ll='ls -l'
  alias lla='la -l'
  alias ld='ls --depth=1 --tree'
  alias lld='ld -l'
  alias lldd='ls --depth=2 --tree -l'
fi

# Bat and Moor are modern replacements for displaying file contents and paging
{{- if and (lookPath "bat") (lookPath "moor") }}
alias cat='bat'
alias less='moor'
{{- end }}

# fd is a modern replacement for find
if command -v fd &>/dev/null; then
	alias fd='fd --hidden'
fi

# Helix
if command -v hx &>/dev/null; then
  alias vim='hx'
  alias vi='hx'
elif command -v nvim &>/dev/null; then
  alias vim='nvim'
  alias vi='nvim'
fi

# Wget
alias wget='wget --hsts-file="${XDG_CACHE_HOME}/wget-hsts"'

# Zellij
# alias zat='session=$(zj ls -ns | fzf --exit-0 || echo "") && [ -n "$session" ] && zj a "$session" || true'

# Dust
alias dust='dust -r'

# Conveniences
alias zshrc='${=EDITOR} ${ZDOTDIR:-$XDG_CONFIG_HOME}/.zshrc'
alias -g H='| head'
alias -g T='| tail'
alias -g G='| grep'
alias -g L="| less"
alias du='du -cx'
alias dud='du -d 1 -h'
alias duf='du -sh *'
alias h='history'
alias sortnr='sort -n -r'
alias unexport='unset'
alias rm='rm -I'
alias cp='cp -i'
alias mv='mv -i'

# Show list of Zsh functions and completions available
alias showfunk='print -l ${(ok)functions}'
