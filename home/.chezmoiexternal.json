{
  ".local/share/nvim/site/autoload/plug.vim": {
    "type": "file",
    "url": "https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim",
    "refreshPeriod": "604800"
  },
  ".cache/zsh4humans/v5/ohmyzsh/ohmyzsh": {
    "type": "archive",
    "url": "https://github.com/ohmyzsh/ohmyzsh/archive/master.tar.gz",
    "exact": true,
    "stripComponents": "1",
    "refreshPeriod": "604800"
  },
  ".cache/zsh4humans/v5/agkozak/zsh-z": {
    "type": "archive",
    "url": "https://github.com/agkozak/zsh-z/archive/master.tar.gz",
    "exact": true,
    "stripComponents": "1",
    "refreshPeriod": "604800",
    "include": ["*/*.zsh", "*/_zshz"]
  },
  ".cache/zsh4humans/v5/djui/alias-tips": {
    "type": "archive",
    "url": "https://github.com/djui/alias-tips/archive/master.tar.gz",
    "exact": true,
    "stripComponents": "1",
    "refreshPeriod": "604800",
    "include": ["*/alias-tips.*"]
  },
  ".local/share/tmux/plugins/tpm": {
    "type": "archive",
    "url": "https://github.com/tmux-plugins/tpm/archive/master.tar.gz",
    "exact": true,
    "stripComponents": "1",
    "refreshPeriod": "604800"
  }
}
